DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 用户注册登录（JWT）。生产环境务必改为长随机串
JWT_SECRET=change-me-to-a-long-random-string
# 生产环境 HTTPS 时设为 1，使 Cookie 带 Secure
AUTH_COOKIE_SECURE=1

# 允许的前端域名（逗号分隔）。不设则允许所有来源。
# 部署后填入 Vercel 给的前端 URL
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# 可选：自定义 SQLite 路径（默认 backend/data/app.db）
# DATABASE_URL=sqlite:///./data/app.db

# ── Hugging Face（sentence-transformers 首次会从 Hub 下载模型）──
# 国内访问 huggingface.co 易超时：任选一种方式
# USE_HF_MIRROR=1
# 或显式指定镜像端点：
# HF_ENDPOINT=https://hf-mirror.com
# 仅想起服务、稍后再下载模型时：
SKIP_EMBEDDER_WARMUP=1
